APP_NAME="Belgrade Luggage Locker"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Initial admin seeded on first migration. Change before going live.
ADMIN_INITIAL_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=changeme

# Timezone used for human-readable timestamps in admin UI / unlock records.
DISPLAY_TIMEZONE=Europe/Belgrade

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Comma-separated hosts that receive stateful Sanctum cookies. In production,
# set this to your subdomain (e.g. "lockers.example.com").
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
# Cookie domain for SPA session — leave null for single-host, set to ".example.com"
# only if you share auth across subdomains.
SESSION_DOMAIN=null

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=luggage_lockers
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# In production: run `php artisan queue:work` via supervisor and add a cron entry
# `* * * * * cd /path && php artisan schedule:run >> /dev/null 2>&1` for routes/console.php jobs.

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="info@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── Notifications dev-mode (redirect customer-bound mail / WhatsApp) ─────────
# When NOTIFICATIONS_DEV_MODE=true, booking confirmation + PIN delivery emails
# and WhatsApp messages are redirected to DEV_EMAIL_TO / DEV_WHATSAPP_TO.
# This avoids spamming real customers while testing. Settings UI overrides these.
NOTIFICATIONS_DEV_MODE=false
DEV_EMAIL_TO=
DEV_WHATSAPP_TO=
# Hard kill-switch — when true, no booking notifications are sent at all.
NOTIFICATIONS_DISABLED=false

# ─── TTLock ─────────────────────────────────────────────────────────────────
TTLOCK_CLIENT_ID=
TTLOCK_CLIENT_SECRET=
TTLOCK_USERNAME=
TTLOCK_PASSWORD=
TTLOCK_BASE_URL=https://euapi.ttlock.com
# CA bundle path — only needed on Windows dev where PHP can't find system certs.
# Leave empty on Linux production.
TTLOCK_CA_BUNDLE=

# ─── WhatsApp Business (Meta Cloud API) ────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
